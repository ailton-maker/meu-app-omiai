rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isParticipant(participants) { return isSignedIn() && request.auth.uid in participants; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Validation Helpers ---
    function isValidUser(data) {
      return (data.uid == request.auth.uid || data.uid.startsWith('demo'))
        && data.displayName is string && data.displayName.size() > 0 
        && data.displayName.size() <= 100;
    }

    // --- Collections ---

    match /users/{userId} {
      // Users can see other users (basic info) but only edit their own
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(userId) || userId.startsWith('demo')) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'interests', 'hobbies', 'hometown', 'occupation', 'gender', 'preferences', 'lastSeenLocation', 'lastSeenAt', 'updatedAt', 'onboardingCompleted', 'inviteCode', 'referredBy', 'premiumExpiry', 'hasSeenMatchTutorial']))
        && incoming().uid == existing().uid;
    }

    match /crossings/{crossingId} {
      // Only participants of a crossing can see it
      allow read: if isParticipant(existing().participants);
      allow create: if isSignedIn() && request.auth.uid in incoming().participants && incoming().participants.size() == 2
        && incoming().timestamp == request.time;
    }

    match /likes/{likeId} {
      // A user can see likes they sent or received
      allow read: if isOwner(existing().fromUid) || isOwner(existing().toUid);
      allow create: if isOwner(incoming().fromUid) && incoming().timestamp == request.time;
      allow delete: if isOwner(existing().fromUid);
    }

    match /notifications/{notificationId} {
      // Only the recipient can read their notifications
      allow read: if isOwner(existing().toUid);
      // Anyone can create a notification for another user (or we could restrict to if they have a match/interaction)
      // For simplicity in this demo, allow if sender is the one who took the action
      allow create: if isOwner(incoming().fromUid) && incoming().timestamp == request.time;
    }

    match /chats/{chatId} {
      allow read: if isParticipant(existing().participants);
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isParticipant(existing().participants) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'unreadCount']);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      allow create: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
        && isOwner(incoming().senderId)
        && incoming().timestamp == request.time;
      // Participants can mark messages as read
      allow update: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
